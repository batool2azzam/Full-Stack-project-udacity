{
  "name": "ts-image-processing-api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "node -r ts-node/register ./node_modules/jasmine/bin/jasmine.js --config=jasmine.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.cjs\" \"*.md\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jasmine": "^5.1.4",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "jasmine": "^5.6.2",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
